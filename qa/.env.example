# Copy to .env and adjust. Never commit real credentials.
BASE_URL=http://localhost:8080
API_URL=http://localhost:8080/api/v1/

# Optional: domain and prefix for generated users (no secrets)
TEST_EMAIL_DOMAIN=test.local
TEST_USERNAME_PREFIX=test

# Playwright / API tuning (milliseconds)
# PW_TEST_TIMEOUT_MS=60000
# PW_EXPECT_TIMEOUT_MS=10000
# PW_ACTION_TIMEOUT_MS=15000
# PW_NAVIGATION_TIMEOUT_MS=30000
# PW_POST_AUTH_REDIRECT_MS=15000
# PW_ERROR_BANNER_MS=5000
# API_RATE_LIMIT_BACKOFF_MS=12000
# GLOBAL_SETUP_RATE_LIMIT_MS=10000

# Reports (paths relative to qa/)
# PW_JSON_REPORT_FILE=test-results/results.json
# PW_JUNIT_REPORT_FILE=test-results/junit.xml

# CI=true
